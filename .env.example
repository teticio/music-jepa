# Music JEPA environment overrides. Copy to .env and uncomment what you need.
# .env is gitignored; the Makefile reads it via `-include .env`.

# How many GPUs torchrun should spawn for `make train-encoder`.
# NPROC_PER_NODE=2

# ---- Full dataset (defaults — leave unset to use these) --------------------
# CHECKPOINT_DIR=checkpoints
# CHECKPOINT_NAME=last.ckpt
# EMBEDDINGS_DIR=embeddings
# EMBEDDINGS_FILE=embeddings/embeddings.npy
# TRAIN_CONFIG=configs/encoder.yaml
# HEAD_CONT_CONFIG=configs/head_continuation.yaml
# HEAD_INFIL_CONFIG=configs/head_infil.yaml
# HEAD_CONT_CKPT=checkpoints/continuation_head.pt
# HEAD_INFIL_CKPT=checkpoints/infill_head.pt
# TRACKS_FILE=data/tracks_dedup.csv
# OUTPUT_DIR=outputs
# PAGES_BRANCH=gh-pages
# PAGES_WORKTREE=/tmp/music-jepa-pages

# ---- Sample preset (uncomment to swap) -------------------------------------
# CHECKPOINT_DIR=checkpoints-sample
# EMBEDDINGS_DIR=embeddings-sample
# EMBEDDINGS_FILE=embeddings-sample/embeddings.npy
# TRAIN_CONFIG=configs/encoder_sample.yaml
# HEAD_CONT_CONFIG=configs/head_continuation_sample.yaml
# HEAD_INFIL_CONFIG=configs/head_infil_sample.yaml
# HEAD_CONT_CKPT=checkpoints-sample/continuation_head.pt
# HEAD_INFIL_CKPT=checkpoints-sample/infill_head.pt
# TRACKS_FILE=data/tracks_sample.csv
# OUTPUT_DIR=outputs-sample

# ---- Patch-head paths (alternative pooling — see docs/jepa-architecture.md) ------
# These knobs are read by the *-patch Make targets (train-head-patch-*,
# embed-patch-*, playlist-patch, journey-patch, examples-patch, app-patch).
# EMBEDDINGS_FILE remains the base encoder catalog; the patch catalogs are used
# for the head side of HEAD_WEIGHT blending.
# HEAD_CONT_PATCH_CONFIG=configs/head_continuation_patch.yaml
# HEAD_INFIL_PATCH_CONFIG=configs/head_infil_patch.yaml
# HEAD_CONT_PATCH_CKPT=checkpoints/continuation_head_patch.pt
# HEAD_INFIL_PATCH_CKPT=checkpoints/infill_head_patch.pt
# EMBEDDINGS_PATCH_CONT=embeddings/embeddings_patch_cont.npy
# EMBEDDINGS_PATCH_INFIL=embeddings/embeddings_patch_infil.npy
