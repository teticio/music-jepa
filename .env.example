# Music JEPA environment overrides. Copy to .env and uncomment what you need.
# .env is gitignored; the Makefile reads it via `-include .env`.

# How many GPUs torchrun should spawn for `make train`.
# NPROC_PER_NODE=2

# ---- Full dataset (defaults — leave unset to use these) --------------------
# CHECKPOINT_DIR=checkpoints
# TRAIN_CONFIG=configs/train.yaml
# HEAD_CONT_CONFIG=configs/head_continuation.yaml
# HEAD_INFIL_CONFIG=configs/head_infil.yaml
# TRACKS_FILE=data/tracks_dedup.csv

# ---- Sample preset (uncomment to swap) -------------------------------------
# CHECKPOINT_DIR=checkpoints-sample
# TRAIN_CONFIG=configs/sample.yaml
# HEAD_CONT_CONFIG=configs/head_continuation_sample.yaml
# HEAD_INFIL_CONFIG=configs/head_infil_sample.yaml
# TRACKS_FILE=data/tracks_sample.csv
